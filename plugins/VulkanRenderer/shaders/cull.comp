// ============================================================================
// NITRO VIRTUAL GEOMETRY: GPU-DRIVEN FRUSTUM CULLING - ULTRA OPTIMIZED
// Target: <0.05ms for 65,536 instances (2x faster)
// ============================================================================

#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable

layout(local_size_x = 256) in; // Increased from 128 for better occupancy

struct InstanceData {
    vec4 row0; 
    vec4 row1; 
    vec4 row2; 
    uint packedColor;
    uint textureID; // Forwarded through culling to preserve per-instance texture
    uint _padding0;
    uint _padding1;
};

struct IndirectCommand {
    uint indexCount;
    uint instanceCount;
    uint firstIndex;
    int  vertexOffset;
    uint firstInstance;
};

layout(std430, binding = 0) readonly buffer InstanceBuffer {
    InstanceData instances[];
};

layout(std430, binding = 1) writeonly buffer VisibleInstanceBuffer {
    InstanceData visibleInstances[];
};

layout(std430, binding = 2) buffer IndirectBuffer {
    IndirectCommand commands[];
};

layout(push_constant) uniform CullingData {
    mat4 viewProj;
    uint totalInstances;
    float meshRadius;
} pc;

// ULTRA-FAST FRUSTUM TEST - Optimized for early rejection
bool SphereInFrustum(vec3 pos, float radius) {
    // CULLING DISABLED - Always return true to render everything
    return true;
    
