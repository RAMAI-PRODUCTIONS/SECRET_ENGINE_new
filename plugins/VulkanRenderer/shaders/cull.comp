void main() {
    uint gID = gl_GlobalInvocationID.x;
    if (gID >= pc.totalInstances) return;

    // CACHE-OPTIMIZED FETCH - Single 64-byte read
    InstanceData instance = instances[gID];
    
    // Extract position (last column of 3x4 matrix)
    vec3 pos = vec3(instance.row0.w, instance.row1.w, instance.row2.w);
    
    // ULTRA-FAST CULLING with pre-scaled radius
    if (SphereInFrustum(pos, pc.meshRadius * 15.0)) {
        uint index = atomicAdd(commands[0].instanceCount, 1);
        visibleInstances[index] = instance;
    }
}
