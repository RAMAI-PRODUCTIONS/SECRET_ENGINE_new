{
  "version": "1.0",
  "description": "Runtime UI Configuration for FPS Game",
  
  "screen_zones": {
    "ui_buttons_zone": {
      "enabled": true,
      "position": "top",
      "height_percent": 15.0,
      "comment": "Top area reserved for UI buttons"
    },
    "joystick_zone": {
      "enabled": true,
      "side": "left",
      "comment": "Left half of screen for movement joystick"
    },
    "look_zone": {
      "enabled": true,
      "side": "right",
      "comment": "Right half of screen for camera look and fire"
    }
  },
  
  "ui_buttons": [
    {
      "id": "btn_menu",
      "label": "MENU",
      "action": "MainMenu",
      "position_index": 0,
      "color": [0.2, 0.3, 0.5],
      "text_color": [1.0, 1.0, 1.0],
      "visible": true
    },
    {
      "id": "btn_scene",
      "label": "SCENE",
      "action": "Scene",
      "position_index": 1,
      "color": [0.3, 0.5, 0.3],
      "text_color": [1.0, 1.0, 1.0],
      "visible": true
    },
    {
      "id": "btn_arena",
      "label": "ARENA",
      "action": "FPS_Arena",
      "position_index": 2,
      "color": [0.5, 0.2, 0.2],
      "text_color": [1.0, 1.0, 1.0],
      "visible": true
    },
    {
      "id": "btn_race",
      "label": "RACE",
      "action": "RacingTrack",
      "position_index": 3,
      "color": [0.5, 0.4, 0.2],
      "text_color": [1.0, 1.0, 1.0],
      "visible": true
    }
  ],
  
  "joystick": {
    "enabled": true,
    "position": {
      "x_ndc": -0.7,
      "y_ndc": 0.5,
      "comment": "NDC coordinates: -1 to 1"
    },
    "size": {
      "base_size": 0.3,
      "stick_size": 0.1,
      "max_offset_multiplier": 0.5
    },
    "colors": {
      "base": [0.2, 0.2, 0.2],
      "stick": [1.0, 1.0, 1.0]
    },
    "touch_radius_pixels": 100.0,
    "visible": true
  },
  
  "touch_input": {
    "joystick_sensitivity": 1.0,
    "look_sensitivity": 10.0,
    "fire_on_tap": true,
    "comment": "Input sensitivity multipliers"
  },
  
  "layout": {
    "button_inset": 0.01,
    "button_text_scale": 0.035,
    "button_text_spacing": 0.045,
    "button_text_y_offset": 0.3,
    "comment": "Visual spacing and sizing"
  }
}
